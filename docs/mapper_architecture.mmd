flowchart LR
  W["Workload JSON\n(tasks+tensors+deps)"] --> L["Workload Loader\n(workload/json_io.cpp)"]
  H["Hardware JSON\n(devices+links)"] --> T["Topology Loader\n(hardware_topology/json_io.cpp)"]

  L --> TG["TaskGraph\ncompute nodes + deps\n(no comm bytes)"]
  T --> TG

  TG --> DP["Data Parallel Expand\nexpand_data_parallel()"]
  DP --> COMM["Comm Inference\nannotate_comm_bytes()\nedge.bytes"]

  COMM --> MAP["Mapper\nHEFT / Greedy"]
  MAP --> PLAN["MappingPlan\n(task→device)"]

  COMM --> TF["Taskflow Writer\ntaskflow/taskflow.cpp"]
  PLAN --> TF
  T --> TF

  TF --> OUT["taskflow.json\n(tasks + edges)"]
  TF --> VIZ["taskflow.svg\n(graphviz)"]

